    "avatar",
    "initials",
    "lettermark",
    "placeholder",
    "fallback"
  ],
  "author": "tomaszbilka",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tomaszbilka/lettermark.git",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/tomaszbilka/lettermark/issues"
  },
  "homepage": "https://github.com/tomaszbilka/lettermark#readme",
