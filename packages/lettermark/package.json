{
  "name": "lettermark",
  "version": "0.0.2",
  "description": "Turn a name into initials — lightweight, zero-dependency, framework-agnostic core for avatar fallbacks. Full API coming soon.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "initials",
    "avatar",
    "monogram",
    "lettermark",
    "placeholder",
    "fallback"
  ],
  "author": "tomaszbilka",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tomaszbilka/lettermark.git",
    "directory": "packages/lettermark"
  },
  "bugs": {
    "url": "https://github.com/tomaszbilka/lettermark/issues"
  },
  "homepage": "https://github.com/tomaszbilka/lettermark#readme",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  }
